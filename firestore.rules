rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles - anyone authed can read, only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;

      // Friends subcollection
      match /friends/{friendId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId
                     || request.auth.uid == friendId;
      }

      // Friend requests - recipient can read/delete, anyone authed can create
      match /friendRequests/{requestId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == userId;
      }

      // Nudges (拍一拍) - recipient can read/delete, any authed user can create
      match /nudges/{nudgeId} {
        allow read, delete: if request.auth.uid == userId;
        allow create: if request.auth != null;
      }

      // Ring nudges (响铃拍一拍) - same pattern as nudges
      match /ringNudges/{nudgeId} {
        allow read, delete: if request.auth.uid == userId;
        allow create: if request.auth != null;
      }

      // Shared dues - owner writes, authed users read
      match /sharedDues/{dueId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      // Project memberships - owner reads/writes own memberships
      match /projectMemberships/{membershipId} {
        allow read: if request.auth.uid == userId;
        allow write: if request.auth != null;
      }

      // Project invites - recipient reads/deletes, any authed user can create
      match /projectInvites/{inviteId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == userId;
      }

      // Study goals - private to owner
      match /studyGoals/{goalId} {
        allow read, write: if request.auth.uid == userId;

        match /checkIns/{checkInId} {
          allow read, write: if request.auth.uid == userId;
        }
      }

      // Countdown events - private to owner
      match /countdownEvents/{eventId} {
        allow read, write: if request.auth.uid == userId;
      }

      // User settings (timezone, prefs) - private to owner
      match /settings/{settingsId} {
        allow read, write: if request.auth.uid == userId;
      }

      // Deadline records (EventKit completion flags) - private to owner
      match /deadlineRecords/{recordId} {
        allow read, write: if request.auth.uid == userId;
      }

      // AI account metadata (no secrets) - private to owner
      match /aiAccounts/{accountId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Team Projects - members can read, authed users can create/update
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.memberIds
                        || request.auth.uid in request.resource.data.memberIds);
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.createdBy;

      // Project dues - project members can read/write
      match /dues/{dueId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Meetup locations - members read, owner of doc writes
      match /meetupLocations/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == uid;
        allow delete: if request.auth != null;
      }

      // Project activity log - members can read, authed can create
      match /activities/{activityId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }
  }
}
